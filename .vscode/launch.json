{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    {
        "name": "Django",
        "type": "debugpy",
        "request": "launch",
        "program": "${workspaceFolder}/manage.py",
        "args": [
            "runserver"
        ],
        "django": true,
        "env": {
            "DJANGO_ENVIRONMENT": "DEVELOPMENT"
        },
        "console": "integratedTerminal"
    },
    {
        "name": "React (Chrome)",
        "type": "chrome",
        "request": "launch",
        "url": "http://localhost:8000",
        "webRoot": "${workspaceFolder}/aiarena/frontend-spa",
        "preLaunchTask": "Frontend (React)"
    },
    {
        "name": "Relay",
        "type": "node-terminal",
        "request": "launch",
        "command": "npm run start_relay",
        "cwd": "${workspaceFolder}/aiarena/frontend-spa"
    },
        {
            "name": "Application run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:8000"
            ],
            "django": true,
            "justMyCode": true
        },
        {
            "name": "Migrate",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "migrate"
            ],
            "django": true,
            "justMyCode": true
        },
        {
            "name": "Test",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "test"
            ],
            "django": true,
            "justMyCode": true
        },
    ],
    "compounds": [
        {
            "name": "Full Stack 🚀",
            "configurations": [
                "Django",
                "React (Chrome)",
                "Relay"
            ]
    }
]
}